# Copy this to .env and fill in your values

# LLM provider (primary) — OpenRouter free models. Add $10 one-time credit
# to unlock 1,000 free requests/day (50/day without it). openrouter.ai/keys
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional model overrides (defaults are set in llm.py)
# LLM_MODEL_HEAVY=nvidia/nemotron-3-ultra-550b-a55b:free
# LLM_MODEL_FAST=nvidia/nemotron-3-nano-30b-a3b:free

# Fallback providers (used automatically when OpenRouter fails)
GROQ_API_KEY=your_groq_api_key_here
TOGETHER_API_KEY=your_together_api_key_here   # api.together.ai

# Dashboard login
CC_SECRET_KEY=your-random-secret-key
CC_USERNAME=your_username
CC_PASSWORD=your_password

# Telegram bot (optional) — message @BotFather to create one, then message your
# new bot anything; it captures TELEGRAM_CHAT_ID automatically on first contact.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=
