# Copy this to .env and fill in your values

# LLM APIs
GROQ_API_KEY=your_groq_api_key_here
TOGETHER_API_KEY=your_together_api_key_here   # fallback when Groq hits daily limit — api.together.ai

# Dashboard login
CC_SECRET_KEY=your-random-secret-key
CC_USERNAME=your_username
CC_PASSWORD=your_password
